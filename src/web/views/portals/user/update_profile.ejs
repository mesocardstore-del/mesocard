<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meso Card</title>
    <script src="/static/scripts/tailwind3.4.16.js"></script>
    <link rel="stylesheet" href="/static/styles/home.css">
    <link rel="stylesheet" href="/static/styles/animate.min.css">
    <script>
        tailwind.config = {
          darkMode: 'class',
          theme: {
            extend: {
              colors: {
                primary: {
                  DEFAULT: '#3B82F6',
                  '50': '#EBF2FF',
                  '100': '#D6E4FF',
                  '200': '#ADCAFD',
                  '300': '#85B0FC',
                  '400': '#5C96FB',
                  '500': '#3B82F6',
                  '600': '#0B61EF',
                  '700': '#084BBD',
                  '800': '#06368A',
                  '900': '#042158'
                },
              }
            }
          }
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
    <div class="min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <%- include('../../partials/user/navbar') %>
        
        <!-- Sidebar and Main Content -->
        <div class="flex flex-column pt-12">
            <!-- Sidebar -->
            <%- include('../../partials/user/sidebar') %>
        </div>

        <!-- Main Content -->
        <main class="flex-1 p-4 md:p-6 md:<%= language === 'ar' ? 'mr-64' : 'ml-64' %>">
            <div class="max-w-3xl mx-auto bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
                <!-- Profile Header with Photo -->
                <div class="bg-gradient-to-r from-primary-500 to-primary-700 h-32 relative">
                    <div class="absolute -bottom-16 left-1/2 transform -translate-x-1/2">
                        <div class="relative group">
                            <div class="w-32 h-32 rounded-full border-4 border-white dark:border-gray-800 overflow-hidden bg-white dark:bg-gray-700">
                                <img src="<%= user?.profileImage || '/static/images/avatar/default-avatar.png' %>" alt="Profile" class="profile-image w-full h-full object-cover cursor-pointer transition-all duration-300">
                            </div>
                            <div class="absolute inset-0 bg-black bg-opacity-50 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                <label class="cursor-pointer p-2 rounded-full bg-white bg-opacity-80">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    <input type="file" id="profileImage" class="hidden" accept="image/*">
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
        
                <!-- Profile Form -->
                <div class="mt-20 px-6 py-4">
                    <h2 class="text-2xl font-bold text-center text-gray-800 dark:text-white mb-6">
                        <%= language === 'ar' ? 'تحديث الملف الشخصي' : 'Update Profile' %>
                    </h2>
                    
                    <form id="update-profile-form" class="space-y-6" enctype="multipart/form-data">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- First Name -->
                            <div>
                                <label for="firstName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    <%= language === 'ar' ? 'الاسم الأول' : 'First Name' %>
                                </label>
                                <input type="text" id="firstName" name="firstName" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-gray-700 dark:text-white"
                                    value="<%= user?.firstName || '' %>" required>
                            </div>
                            
                            <!-- Last Name -->
                            <div>
                                <label for="lastName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    <%= language === 'ar' ? 'الاسم الأخير' : 'Last Name' %>
                                </label>
                                <input type="text" id="lastName" name="lastName" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-gray-700 dark:text-white"
                                    value="<%= user?.lastName || '' %>">
                            </div>
                            
                            <!-- Email -->
                            <div>
                                <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    <%= language === 'ar' ? 'البريد الإلكتروني' : 'Email' %>
                                </label>
                                <input type="email" id="email" name="email" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-gray-700 dark:text-white"
                                    value="<%= user?.email || '' %>" required>
                            </div>
                            
                            <!-- Phone -->
                            <div class="md:col-span-1">
                                <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    <%= language === 'ar' ? 'رقم الهاتف' : 'Phone Number' %>
                                </label>
                                <input type="tel" id="phone" name="phone" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-gray-700 dark:text-gray-400 text-gray-500"
                                    value="+<%= user?.phoneNumber || '' %>" disabled>
                            </div>
                        </div>
                        
                        <!-- Save Button -->
                        <div class="flex justify-end pt-4">
                            <button id="update-profile-button" type="submit" class="px-6 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors">
                                <%= language === 'ar' ? 'حفظ التغييرات' : 'Save Changes' %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
        
        <%- include('../../partials/footer') %>
    </div>

<script src="/static/js/sweetalert2.js"></script>
<script src="/static/js/custom.js"></script>
<script>
    // Toggle dark mode
    const themeToggleBtn = document.getElementById('theme-toggle');
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });

    // Check for saved theme preference
    if (localStorage.getItem('theme') === 'dark' || 
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    // Toggle sidebar on mobile
    const toggleSidebarBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');
    toggleSidebarBtn.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
      sidebar.classList.toggle('translate-x-0');
    });

    // Toggle language dropdown
    const languageDropdownBtn = document.getElementById('language-dropdown-btn');
    const languageDropdown = document.getElementById('language-dropdown');
    languageDropdownBtn.addEventListener('click', () => {
      languageDropdown.classList.toggle('hidden');
    });
    
    // User menu toggle
    const userMenuBtn = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    userMenuBtn.addEventListener('click', () => {
      userMenu.classList.toggle('hidden');
    });
    
    // Close user menu when clicking outside
    document.addEventListener('click', (event) => {
      if (!userMenuBtn.contains(event.target) && !userMenu.contains(event.target)) {
        userMenu.classList.add('hidden');
      }
    });

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // Fetch user profile information
            const response = await fetch('/app/profile');
            
            if (!response.ok) {
                throw new Error('Failed to fetch user profile');
            }

            const userData = await response.json();

            // Update user menu details
            const userNameElement = document.querySelector('#user-menu .text-sm.font-medium');
            const userEmailElement = document.querySelector('#user-menu .text-xs.text-gray-500');
            const sidebarNameElement = document.querySelector('#user-profile p.font-medium');
            const sidebarRoleElement = document.querySelector('#user-profile p.text-xs');

            if (userNameElement) {
                userNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (userEmailElement) {
                userEmailElement.textContent = userData.email || 'user@example.com';
            }

            if (sidebarNameElement) {
                sidebarNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (sidebarRoleElement) {
                sidebarRoleElement.textContent = userData.role || 'Account';
            }

        } catch (error) {
            console.error('Error fetching user profile:', error);
            // Optionally, show a user-friendly error message
        }

        // User menu toggle functionality
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        userMenuButton.addEventListener('click', () => {
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (event) => {
            if (!userMenuButton.contains(event.target) && !userMenu.contains(event.target)) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        // Toggle dropdown visibility
        userMenuButton.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevent event from bubbling
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!userMenu.classList.contains('hidden') && 
                !userMenu.contains(e.target) && 
                e.target !== userMenuButton) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    class UpdateProfile {
        constructor() {
            this.form = document.getElementById('update-profile-form');
            this.profileImage = document.getElementsByClassName('profile-image')[0];
            this.profileImageInput = document.getElementById('profileImage');
            this.firstName = document.getElementById('firstName');
            this.lastName = document.getElementById('lastName');
            this.email = document.getElementById('email');
            this.setupEventListeners();
        }

        setupEventListeners() {
            this.form.addEventListener('submit', this.handleSubmit.bind(this));
            this.profileImageInput.addEventListener('change', (e) => this.previewImage(e.target));
        }

        async handleSubmit(e) {
            e.preventDefault();
            await this.updateProfile();
        }

        previewImage(input) {
            if (!input.files || !input.files[0]) {
                this.profileImage.src = "<%= user?.profileImage || '/static/images/avatar/default-avatar.png' %>";
                return;
            }
            const reader = new FileReader();
            const file = input.files[0];

            reader.onloadend = (e) => {
                this.profileImage.src = reader?.result;
            };

            if (file) {
                reader.readAsDataURL(file);
            } else {
                this.profileImage.src = "<%= user?.profileImage || '/static/images/avatar/default-avatar.png' %>";
            }
        }
        
        loadingState(state) {
            if (state === true) {
                document.getElementById('update-profile-button').disabled = true;
                this.profileImageInput.disabled = true;
                this.firstName.disabled = true;
                this.lastName.disabled = true;
                this.email.disabled = true;

                document.getElementById('update-profile-button').classList.add('animate-pulse');
            } else {
                document.getElementById('update-profile-button').disabled = false;
                this.profileImageInput.disabled = false;
                this.firstName.disabled = false;
                this.lastName.disabled = false;
                this.email.disabled = false;

                document.getElementById('update-profile-button').classList.remove('animate-pulse');
            }
        }

        async updateProfile() {
            const formData = new FormData();
            formData.append('firstName', this.firstName?.value);
            formData.append('lastName', this.lastName?.value);
            formData.append('email', this.email?.value);

            if (this.profileImageInput?.files[0]) {
                formData.append('profileImage', this.profileImageInput.files[0]);
            }

            try {
                const response = await fetch('/api/v1/user/profile/update', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response?.ok) {
                    this.loadingState(true);
                    // set timeout to refresh without cache
                    successAlert("<%= language === 'ar' ? 'تم تحديث الملف الشخصي بنجاح' : 'Profile updated successfully' %>");
                    setTimeout(() => {
                        window.location.reload(true);
                    }, 1000);
                } else {
                    this.loadingState(true);
                    errorAlert(result?.message);
                    setTimeout(() => {
                        window.location.reload(true);
                    }, 1200);
                }
            } catch (error) {
                this.loadingState(true);
                errorAlert("<%= language === 'ar' ? 'حدث خطأ اثناء تحديث الملف الشخصي' : 'An error occurred while updating the profile' %>");
                console.error('Error updating profile:', error);
                setTimeout(() => {
                    window.location.reload(true);
                }, 1000);
            }
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        window.updateProfile = new UpdateProfile();
    });
</script>
<script src="/static/js/profile.js"></script>
<script src="/static/js/language.js"></script>
<script src="/static/js/nav.js"></script>
<script src="/static/js/notification-bell.js"></script>
</body>
</html>