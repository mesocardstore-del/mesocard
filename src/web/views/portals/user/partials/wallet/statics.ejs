<!-- Make 3 responsive squares that have balance, total purchases, and received balance with colors -->
<div class="flex flex-wrap gap-4">
    <div class="w-full md:w-1/3 bg-green-600 dark:bg-green-500 shadow overflow-hidden sm:rounded-lg p-4">
        <div class="flex items-center justify-between">
            <div class="text-md font-semibold text-gray-200 dark:text-white"><%= wallet.statics.balance %></div>
            <div id="balance" class="text-lg font-semibold text-gray-200 dark:text-white">$0</div>
        </div>
    </div>
    <div class="w-full md:w-1/3 bg-red-600 dark:bg-red-500 shadow overflow-hidden sm:rounded-lg p-4">
        <div class="flex items-center justify-between">
            <div class="text-md font-semibold text-gray-200 dark:text-white"><%= wallet.statics.totalPurchases %></div>
            <div id="totalPurchases" class="text-lg font-semibold text-gray-200 dark:text-white">$0</div>
        </div>
    </div>
    <div class="w-full md:w-1/3 bg-blue-600 dark:bg-blue-500 shadow overflow-hidden sm:rounded-lg p-4">
        <div class="flex items-center justify-between">
            <div class="text-md font-semibold text-gray-200 dark:text-white"><%= wallet.statics.receivedBalance %></div>
            <div id="receivedBalance" class="text-lg font-semibold text-gray-200 dark:text-white">$0</div>
        </div>
    </div>
</div>