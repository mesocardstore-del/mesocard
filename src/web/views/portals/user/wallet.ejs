<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meso Card - <%= wallet.title %></title>
    <script src="/static/scripts/tailwind3.4.16.js"></script>
    <link rel="stylesheet" href="/static/styles/home.css">
    <link rel="stylesheet" href="/static/styles/animate.min.css">
    <script>
        tailwind.config = {
          darkMode: 'class',
          theme: {
            extend: {
              colors: {
                primary: {
                  DEFAULT: '#3B82F6',
                  '50': '#EBF2FF',
                  '100': '#D6E4FF',
                  '200': '#ADCAFD',
                  '300': '#85B0FC',
                  '400': '#5C96FB',
                  '500': '#3B82F6',
                  '600': '#0B61EF',
                  '700': '#084BBD',
                  '800': '#06368A',
                  '900': '#042158'
                },
              }
            }
          }
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
    <div class="min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <%- include('../../partials/user/navbar') %>
        
        <!-- Sidebar and Main Content -->
        <div class="flex flex-column pt-12">
            <!-- Sidebar -->
            <%- include('../../partials/user/sidebar') %>
        </div>

        <!-- Main Content -->
        <main class="flex-1 items-center justify-center p-4 md:p-6 md:<%= language === 'ar' ? 'mr-64' : 'ml-64' %>">
            <!-- Statics -->
            <div class="flex-1 items-center justify-center mt-8 mb-4 w-full max-w-lg sm:max-w-xl md:max-w-2xl lg:max-w-3xl xl:max-w-4xl 2xl:max-w-5xl 3xl:max-w-6xl 4xl:max-w-7xl mx-auto">
                <%- include('./partials/wallet/statics') %>
            </div>
            <!-- Transactions -->
            <div class="flex-1 items-center justify-center mt-8 mb-4 w-full max-w-lg sm:max-w-xl md:max-w-2xl lg:max-w-3xl xl:max-w-4xl 2xl:max-w-5xl 3xl:max-w-6xl 4xl:max-w-7xl mx-auto">
                <%- include('./partials/wallet/table') %>
            </div>
        </main>
        
        <%- include('../../partials/footer') %>
    </div>
<script>
    // Toggle dark mode
    const themeToggleBtn = document.getElementById('theme-toggle');
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });

    // Check for saved theme preference
    if (localStorage.getItem('theme') === 'dark' || 
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    // Toggle sidebar on mobile
    const toggleSidebarBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');
    toggleSidebarBtn.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
      sidebar.classList.toggle('translate-x-0');
    });

    // Toggle language dropdown
    const languageDropdownBtn = document.getElementById('language-dropdown-btn');
    const languageDropdown = document.getElementById('language-dropdown');
    languageDropdownBtn.addEventListener('click', () => {
      languageDropdown.classList.toggle('hidden');
    });
    
    // User menu toggle
    const userMenuBtn = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    userMenuBtn.addEventListener('click', () => {
      userMenu.classList.toggle('hidden');
    });
    
    // Close user menu when clicking outside
    document.addEventListener('click', (event) => {
      if (!userMenuBtn.contains(event.target) && !userMenu.contains(event.target)) {
        userMenu.classList.add('hidden');
      }
    });

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // Fetch user profile information
            const response = await fetch('/app/profile');
            
            if (!response.ok) {
                throw new Error('Failed to fetch user profile');
            }

            const userData = await response.json();

            // Update user menu details
            const userNameElement = document.querySelector('#user-menu .text-sm.font-medium');
            const userEmailElement = document.querySelector('#user-menu .text-xs.text-gray-500');
            const sidebarNameElement = document.querySelector('#user-profile p.font-medium');
            const sidebarRoleElement = document.querySelector('#user-profile p.text-xs');

            if (userNameElement) {
                userNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (userEmailElement) {
                userEmailElement.textContent = userData.email || 'user@example.com';
            }

            if (sidebarNameElement) {
                sidebarNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (sidebarRoleElement) {
                sidebarRoleElement.textContent = userData.role || 'Account';
            }

        } catch (error) {
            console.error('Error fetching user profile:', error);
            // Optionally, show a user-friendly error message
        }

        // User menu toggle functionality
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        userMenuButton.addEventListener('click', () => {
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (event) => {
            if (!userMenuButton.contains(event.target) && !userMenu.contains(event.target)) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        // Toggle dropdown visibility
        userMenuButton.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevent event from bubbling
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!userMenu.classList.contains('hidden') && 
                !userMenu.contains(e.target) && 
                e.target !== userMenuButton) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const transactionsTableBody = document.getElementById('transactionsTableBody');
        const balanceElement = document.getElementById('balance');
        const totalPurchasesElement = document.getElementById('totalPurchases');
        const receivedBalanceElement = document.getElementById('receivedBalance');

        try {
            const response = await fetch('/api/v1/user/wallet/statics', {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            if (response?.ok) {
                const result = await response.json();
                transactionsTableBody.innerHTML = '';
                balanceElement.textContent = '$' + result?.results?.balance || '$0';
                totalPurchasesElement.textContent = '$' + result?.results?.totalPurchases || '$0';
                receivedBalanceElement.textContent = '$' + result?.results?.receivedBalance || '$0';

                if (!result?.transactions || result?.transactions?.length < 1) throw new Error('No transactions found');
                result?.transactions?.forEach(transaction => {
                    const row = document.createElement('tr');
                    row.className = "hover:bg-gray-50 dark:hover:bg-gray-700";
                    const language = "<%= language %>" || 'en';
                    row.innerHTML = `
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-200">${transaction?.id || '-'}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-200">$${transaction?.amount || '-'}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs leading-5 font-semibold ${transaction?.status === 'accepted' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : transaction?.status === 'pending' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'}">
                                ${transaction?.status === 'accepted' ? 
                                    (language === 'ar' ? 'مقبول' : 'Accepted') : 
                                    transaction?.status === 'pending' ? 
                                    (language === 'ar' ? 'قيد الانتظار' : 'Pending') : 
                                    (language === 'ar' ? 'مرفوض' : 'Rejected')
                                }
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-200">
                            ${transaction?.transactionType === 'deposit' ? 
                                (language === 'ar' ? 'إيداع' : 'Deposit') : 
                                transaction?.transactionType === 'withdraw' ?
                                (language === 'ar' ? 'سحب' : 'Withdrawal') :
                                '-'}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-200">
                            ${transaction?.createdAt ? new Date(transaction.createdAt).toLocaleString(
                                "<%= language === 'ar' ? 'ar-EG' : 'en-US' %>", 
                                { 
                                    year: 'numeric', 
                                    month: 'short', 
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit',
                                    hour12: true 
                                }
                            ) : '-'}
                        </td>
                    `;
                    transactionsTableBody.appendChild(row);
                });
            } else {
                throw new Error('Failed to fetch transactions');
            }
        } catch (error) {
            console.error('Error fetching transactions:', error);
            if (error?.message === 'No transactions found') {
                transactionsTableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">
                            <div class="flex justify-center space-x-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <p class="text-gray-500 dark:text-gray-400"><%= wallet.noResults %></p>
                            </div>
                        </td>
                    </tr>
                `;
            } else {
                setTimeout(() => {
                    errorAlert("<%= language === 'ar' ? 'حدث خطأ اثناء جلب المعاملات' : 'An error occurred while fetching transactions' %>");
                    window.location.reload(true);
                }, 1000);
            }
        }
    });
</script>
<script src="/static/js/profile.js"></script>
<script src="/static/js/language.js"></script>
<script src="/static/js/nav.js"></script>
<script src="/static/js/notification-bell.js"></script>
</body>
</html>
