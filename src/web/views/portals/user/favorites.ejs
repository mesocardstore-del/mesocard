<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meso Card</title>
    <script src="/static/scripts/tailwind3.4.16.js"></script>
    <link rel="stylesheet" href="/static/styles/home.css">
    <link rel="stylesheet" href="/static/styles/animate.min.css">
    <script>
        tailwind.config = {
          darkMode: 'class',
          theme: {
            extend: {
              colors: {
                primary: {
                  DEFAULT: '#3B82F6',
                  '50': '#EBF2FF',
                  '100': '#D6E4FF',
                  '200': '#ADCAFD',
                  '300': '#85B0FC',
                  '400': '#5C96FB',
                  '500': '#3B82F6',
                  '600': '#0B61EF',
                  '700': '#084BBD',
                  '800': '#06368A',
                  '900': '#042158'
                },
              }
            }
          }
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
    <%- include('./partials/pageLoading') %>
    <div class="min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <%- include('../../partials/user/navbar') %>
        
        <!-- Sidebar and Main Content -->
        <div class="flex flex-column pt-12">
            <!-- Sidebar -->
            <%- include('../../partials/user/sidebar') %>
        </div>

        <!-- Main Content -->
        <main class="flex-1 items-center justify-center p-4 md:p-6 md:<%= language === 'ar' ? 'mr-64' : 'ml-64' %>">
            <!-- Grid for favorite products with images -->
            <div class="flex-1 items-center justify-center mt-8 mb-4 w-full max-w-lg sm:max-w-xl md:max-w-2xl lg:max-w-3xl xl:max-w-4xl 2xl:max-w-5xl 3xl:max-w-6xl 4xl:max-w-7xl mx-auto">
                <!-- Grid for favorite products with images -->
                <div id="categoryGrid" class="grid grid-cols-3 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 gap-4">
                    <% if (products && typeof products === 'object' && Object.keys(products)?.length > 0) { %>
                        <% Object.entries(products).forEach(([key, product]) => { %>
                            <div class="category-item flex flex-col items-center w-full relative" data-category-name="<%= product.name.toLowerCase() %>" 
                                <% if (product.isAvailable) { %>
                                    onclick="dialogManager.showDialog({
                                    productId: '<%= product.id %>',
                                    title: '<%= product.name %>',
                                    price: '<%= product.price %>',
                                    price_jod: '<%= product.price_jod %>',
                                    minUnits: '<%= product?.minUnits || 1 %>',
                                    description: '<%= product?.dialogDescription ? product?.dialogDescription : product?.dialogDescription %>',
                                    hasForms: <%= product?.dialogHasForms ? 'true' : 'false' %>,
                                    isFavorite: <%= product?.isFavorite ? 'true' : 'false' %>,
                                    formFields: <%= product?.dialogForms ? JSON.stringify(product?.dialogForms) : '[]' %>,
                                    onSubmit: async (formData) => {
                                        try {
                                            const response = await fetch('/api/v1/user/cart/add', {
                                                method: 'POST',
                                                headers: {
                                                    'Content-Type': 'application/json',
                                                },
                                                body: JSON.stringify(formData),
                                            })

                                            return response;
                                        } catch (error) {
                                            console.error('Error adding to cart:', error);
                                            console.error('error adding', formData)
                                            return null;
                                        }
                                    }
                                    });"
                                <% } %>>
                                <input type="text" id="productId" class="hidden" value="<%= product.id %>" />
                                <input type="text" id="productFormName" class="hidden" value="<%= product.dialogFormName %>" />
                                <a href="#" class="w-full <%= !product.isAvailable ? 'cursor-default' : '' %>">
                                    <div class="w-full aspect-square bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden transform transition duration-300 ease-in-out hover:scale-105 relative">
                                        <% if (product.imagePath) { %>
                                            <img 
                                                src="<%= product.imagePath %>" 
                                                alt="<%= product.name %>" 
                                                class="w-full h-full object-cover <%= !product.isAvailable ? 'filter grayscale' : '' %>"
                                                loading="lazy"
                                            >
                                            <% if (!product.isAvailable) { %>
                                                <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center">
                                                    <span class="text-white font-bold text-lg bg-red-500 px-3 py-1 rounded-full">
                                                        <%= language === 'ar' ? 'غير متوفر' : 'Unavailable' %>
                                                    </span>
                                                </div>
                                            <% } %>
                                        <% } else { %>
                                            <div class="w-full h-full bg-gradient-to-br from-primary-500 to-primary-600 dark:from-primary-600 dark:to-primary-700 flex items-center justify-center <%= !product.isAvailable ? 'filter grayscale' : '' %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                                                </svg>
                                            </div>
                                            <% if (!product.isAvailable) { %>
                                                <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-50">
                                                    <span class="text-white font-bold text-lg bg-red-500 px-3 py-1 rounded-full">
                                                        <%= language === 'ar' ? 'غير متوفر' : 'Unavailable' %>
                                                    </span>
                                                </div>
                                            <% } %>
                                        <% } %>
                                    </div>
                                    <h3 class="text-md font-medium text-gray-900 dark:text-gray-100 mt-2 text-center">
                                        <%= product.name %>

                                        <span class="block text-green-700 dark:text-green-400"><%= (product.price * product.minUnits).toFixed(3) %> $</span>
                                        <% if (!product.isAvailable) { %>
                                            <span class="block text-xs text-red-500">(<%= language === 'ar' ? 'غير متوفر' : 'Inactive' %>)</span>
                                            <% } %>
                                    </h3>
                                </a>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div id="noResults" class="hidden text-center text-gray-600 dark:text-gray-400 py-8">
                            <%= noResults %>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
        
        <%- include('./partials/products/dialog') %>
        <%- include('../../partials/footer') %>
    </div>

    <script>
      const setPageLoading = (isLoading) => {
          const loadingOverlay = document.getElementById('loading-overlay');
          if (isLoading) {
              loadingOverlay.classList.remove('hidden');
          } else {
              loadingOverlay.classList.add('hidden');
          }
      }
    </script>
    <script>
      // Dialog management
      class DialogManager {
        constructor() {
          this.cartCountElement = document.getElementById('cart-count');
          this.dialog = document.getElementById('dynamicDialog');
          this.backdrop = document.getElementById('dialogBackdrop');
          this.titleElement = document.getElementById('dialog-title');
          // -
          this.priceElement = document.getElementById('dialog-price');
          this.price_jodElement = document.getElementById('dialog-price_jod');
          this.unitsElement = document.getElementById('dialog-units');
          this.totalPriceElement = document.getElementById('dialog-total-price');
          // -
          this.descriptionElement = document.getElementById('dialog-description');
          this.formElement = document.getElementById('dynamicDialogForm');
          this.unitsContainer = document.getElementById('dialog-units-container');
          this.formFieldsContainer = document.getElementById('dialog-form-fields');
          this.productQuantity = document.getElementById('product-quantity');
          this.productId = document.getElementById('productId');
          this.productDetails = document.getElementById('product-details');
          this.productFormName = document.getElementById('productFormName');
          this.isFavoriteElement = document.getElementById('isFavorite');

          // Add to cart handler
          document.getElementById('add-to-cart')?.addEventListener('click', () => {
            const quantity = parseInt(this.productQuantity.value) || 1;
            // Handle add to cart logic here
            const formData = new FormData();
            formData.append('productId', this.productId.value);
            formData.append('quantity', quantity);
            fetch('/api/v1/user/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(Object.fromEntries(formData.entries())),
            })
            .then(response => response.json())
            .then(data => {
                this.hide();
            })
            .catch(error => {
                console.error('Error adding to cart:', error);
                this.hide();
            });

            this.productQuantity.value = '1'; // Reset quantity
          });

          // Cancel buttons
          document.getElementById('cancel-add-to-cart')?.addEventListener('click', () => this.hide());
          document.getElementById('dialog-cancel')?.addEventListener('click', () => this.hide());
          this.backdrop?.addEventListener('click', () => this.hide());
          
          // Favorite Init
          const initialIsFavorited = this.isFavoriteElement?.dataset.favorited === 'true';
          this.updateFavorite(initialIsFavorited);
          // Favorite handler
          this.isFavoriteElement?.addEventListener('click', () => this.favoriteStateHandler(this.isFavoriteElement.dataset.favorited === 'true'));
        }

        updateFavorite(isFavorite) {
            if (isFavorite) {
                this.isFavoriteElement.classList.remove('text-gray-400', 'dark:text-gray-500', 'hover:bg-gray-500/30', 'dark:hover:bg-gray-700/30');
                this.isFavoriteElement.classList.add('text-red-400', 'dark:text-red-500', 'hover:bg-red-500/30', 'dark:hover:bg-red-700/30')
                this.isFavoriteElement.dataset.favorited = 'true';
            } else {
                this.isFavoriteElement.classList.remove('text-red-400', 'dark:text-red-500', 'hover:bg-red-500/30', 'dark:hover:bg-red-700/30');
                this.isFavoriteElement.classList.add('text-gray-400', 'dark:text-gray-500', 'hover:bg-gray-500/30', 'dark:hover:bg-gray-700/30');
                this.isFavoriteElement.dataset.favorited = 'false';
            }
        }

        favoriteStateHandler(isFavorite) {
          const isFavorited = this.isFavoriteElement.dataset.favorited === 'true';
          const productId = this.isFavoriteElement.dataset.product_id;

          const apiEndpoint = isFavorited ? `/api/v1/user/favorites/${productId}` : `/api/v1/user/favorites/add/${productId}`;
          const method = isFavorited ? 'DELETE' : 'POST';

          this.updateFavorite(!isFavorited);

          fetch(apiEndpoint, {
            method: method,
            headers: {
              'Content-Type': 'application/json',
            }
          })
          .then(response => {
            if (!response.ok) {
              console.error('API request failed:', response.status, response.statusText);
              this.updateFavorite(isFavorited);
              throw new Error('Network response was not ok');
            }
            return response.json();
          })
          .then(data => {
          })
          .catch(error => {
            console.error('Error unfavoriting product:', error);
            this.updateFavorite(isFavorited);
          });

        }

        async getFavoriteState(productId) {
          try {
            const response = await fetch(`/api/v1/user/favorites/${productId}`);
            const data = await response.json();
            // make sure data is not null
            if (!data) {
              return false;
            }

            const isFavorite = data?.results ? true : false;
            return isFavorite;
          } catch (error) {
            console.error('Error getting favorite state:', error);
            return false;
          }
        }

        async showDialog(options) {
          try {
              setPageLoading(true);
              const {
              productId,
              title,
              price,
              price_jod,
              minUnits,
              description = '',
              hasForms = false,
              formFields = [],
              onSubmit = null
              } = options;
          

              // Set title and description
              this.titleElement.textContent = title;
              this.priceElement.textContent = (price * minUnits).toFixed(3) + ' USD';
              this.price_jodElement.textContent = (price_jod * minUnits).toFixed(3) + ' JOD';
              this.unitsElement.value = minUnits;
              this.unitsElement.min = minUnits;

              this.descriptionElement.innerHTML = description || '';
              if (description) {
                  this.descriptionElement.classList.remove('hidden');
              } else {
                  this.descriptionElement.classList.add('hidden');
              }
              
              this.productId.value = productId;
              this.isFavoriteElement.dataset.product_id = productId;
              this.isFavoriteElement.dataset.favorited = await this.getFavoriteState(productId);
              if (this.isFavoriteElement?.dataset.favorited === 'true') {
                  this.updateFavorite(true);
              } else {
                  this.updateFavorite(false);
              }

              // Update total price when units change
              this.unitsElement.addEventListener('input', () => {
                  const value = parseInt(this.unitsElement.value) || 0;
                  this.totalPriceElement.value = (price * Math.max(value, minUnits)).toFixed(3) + ' USD';
              });
              
              this.unitsElement.oninvalid = () => {
                  this.unitsElement.setCustomValidity(`<%= language === 'ar' ? 'من فضلك ادخل قيمه لا تقل عن' : 'Please enter a value that is not less than' %> ${minUnits}`);
              };

              this.unitsElement.oninput = () => {
                  this.unitsElement.setCustomValidity('');
              };

              // Initial calculation
              this.totalPriceElement.value = (price * minUnits).toFixed(3) + ' USD';
              
              this.formElement.classList.remove('hidden');
              // Handle form or add to cart
              if (hasForms) {
                  this.renderFormFields(formFields);
                  if (onSubmit) {
                      this.formElement.onsubmit = async (e) => {
                          e.preventDefault();
                          const tempForm = new FormData(this.formElement);
                          tempForm.delete('units');
                          tempForm.delete('price');
                          
                          const formData = new FormData();
                          formData.append('productId', productId);
                          formData.append('quantity', this.unitsElement.value);

                          formData.append('submittedFields', JSON.stringify(Object.fromEntries(tempForm.entries())));
                          const onSubmitResponse = await onSubmit(Object.fromEntries(formData));
                          // check that if the last submit response ok or not
                          if (onSubmitResponse?.ok) {
                              const successMssg = "<%= language === 'ar' ? 'تم اضافه العنصر للسلة بنجاح' : 'Product added to cart successfully' %>";
                              successAlert(successMssg);
                              // refresh cart counter in navbar
                              this.cartCountElement.textContent = Number(this.cartCountElement.textContent) + 1;
                          } else {
                              const errorMssg = "<%= language === 'ar' ? 'حدث خطأ ما! اثناء اضافة العنصر للسلة' : 'An error occurred while adding the product to the cart' %>";
                              errorAlert(errorMssg);
                          }
                          
                          this.hide();
                      };

                  }
              } else {
                  if (onSubmit) {
                      this.formElement.onsubmit = async (e) => {
                          e.preventDefault();
                          const tempForm = new FormData(this.formElement);
                          tempForm.delete('units');
                          tempForm.delete('price');
                          
                          const formData = new FormData();
                          formData.append('productId', productId);
                          formData.append('quantity', this.unitsElement.value);

                          formData.append('submittedFields', JSON.stringify(Object.fromEntries(tempForm.entries())));
                          const onSubmitResponse = await onSubmit(Object.fromEntries(formData));
                          // check that if the last submit response ok or not
                          if (onSubmitResponse?.ok) {
                              const successMssg = "<%= language === 'ar' ? 'تم اضافه العنصر للسلة بنجاح' : 'Product added to cart successfully' %>";
                              successAlert(successMssg);
                              // refresh cart counter in navbar
                              this.cartCountElement.textContent = Number(this.cartCountElement.textContent) + 1;
                          } else {
                              const errorMssg = "<%= language === 'ar' ? 'حدث خطأ ما! اثناء اضافة العنصر للسلة' : 'An error occurred while adding the product to the cart' %>";
                              errorAlert(errorMssg);
                          }
                          this.hide();
                      };
                  }
              }
              // Show the dialog
              this.dialog.classList.remove('hidden');
              document.body.classList.add('overflow-hidden');
          } catch (error) {
              console.error('Error showing dialog:', error);
              setPageLoading(false);
          } finally {
              setPageLoading(false);
          }
        }
        
        hide() {
            this.dialog.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
            // clear the form
            this.formFieldsContainer.innerHTML = '';
        }
        
        renderFormFields(fields) {
            
            fields = JSON.parse(fields);
            this.formFieldsContainer.innerHTML = '';
            if (fields && Object?.keys(fields)?.length > 0) { 
                Object.entries(fields).forEach(([key, value]) => {
                    const dynamicId = new Date().getTime();
                    const fieldContainer = document.createElement('div');
                    fieldContainer.className = `relative w-full ${value === 'small' ? 'col-span-6' : 'col-span-12'}`;
                    
                    const label = document.createElement('label');
                    label.htmlFor = `${dynamicId}`;
                    label.className = "absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 top-4 z-10 origin-[0] peer-focus:text-blue-600 peer-focus:dark:text-blue-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:-translate-y-4 <%= language === 'ar' ? 'right-2.5 peer-focus:right-2.5' : 'left-2.5 peer-focus:left-2.5' %>";
                    
                    const input = document.createElement('input');
                    //input.type = field.type || 'text';
                    input.type = 'text';
                    input.id = `${dynamicId}`;
                    input.name = key;
                    //input.required = field.required || false;
                    input.required = false;
                    input.className = "block px-2.5 pb-2.5 pt-5 w-full text-sm text-gray-900 dark:text-white bg-white dark:bg-gray-700 rounded-3xl border border-gray-300 dark:border-gray-600 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:focus:border-blue-500 peer <%= language === 'ar' ? 'text-right' : 'text-left' %>";
                    input.placeholder = ' ';
                    input.autocomplete = 'off';
                    
                    label.textContent = key;
                    
                    fieldContainer.appendChild(input);
                    fieldContainer.appendChild(label);
                    this.formFieldsContainer.appendChild(fieldContainer);
                });
            }
        }
    }

      // Initialize dialog manager
      window.dialogManager = new DialogManager();
    </script>
<script>
    // Toggle dark mode
    const themeToggleBtn = document.getElementById('theme-toggle');
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });

    // Check for saved theme preference
    if (localStorage.getItem('theme') === 'dark' || 
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    // Toggle sidebar on mobile
    const toggleSidebarBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');
    toggleSidebarBtn.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
      sidebar.classList.toggle('translate-x-0');
    });

    // Toggle language dropdown
    const languageDropdownBtn = document.getElementById('language-dropdown-btn');
    const languageDropdown = document.getElementById('language-dropdown');
    languageDropdownBtn.addEventListener('click', () => {
      languageDropdown.classList.toggle('hidden');
    });
    
    // User menu toggle
    const userMenuBtn = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    userMenuBtn.addEventListener('click', () => {
      userMenu.classList.toggle('hidden');
    });
    
    // Close user menu when clicking outside
    document.addEventListener('click', (event) => {
      if (!userMenuBtn.contains(event.target) && !userMenu.contains(event.target)) {
        userMenu.classList.add('hidden');
      }
    });

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // Fetch user profile information
            const response = await fetch('/app/profile');
            
            if (!response.ok) {
                throw new Error('Failed to fetch user profile');
            }

            const userData = await response.json();

            // Update user menu details
            const userNameElement = document.querySelector('#user-menu .text-sm.font-medium');
            const userEmailElement = document.querySelector('#user-menu .text-xs.text-gray-500');
            const sidebarNameElement = document.querySelector('#user-profile p.font-medium');
            const sidebarRoleElement = document.querySelector('#user-profile p.text-xs');

            if (userNameElement) {
                userNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (userEmailElement) {
                userEmailElement.textContent = userData.email || 'user@example.com';
            }

            if (sidebarNameElement) {
                sidebarNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (sidebarRoleElement) {
                sidebarRoleElement.textContent = userData.role || 'Account';
            }

        } catch (error) {
            console.error('Error fetching user profile:', error);
            // Optionally, show a user-friendly error message
        }

        // User menu toggle functionality
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        userMenuButton.addEventListener('click', () => {
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (event) => {
            if (!userMenuButton.contains(event.target) && !userMenu.contains(event.target)) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        // Toggle dropdown visibility
        userMenuButton.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevent event from bubbling
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!userMenu.classList.contains('hidden') && 
                !userMenu.contains(e.target) && 
                e.target !== userMenuButton) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script src="/static/js/profile.js"></script>
<script src="/static/js/language.js"></script>
<script src="/static/js/nav.js"></script>
<script src="/static/js/notification-bell.js"></script>
<script src="/static/js/sweetalert2.js"></script>
<script src="/static/js/custom.js"></script>
</body>
</html>
