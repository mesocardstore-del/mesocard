<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= adminHome.title %></title>
    <script src="/static/scripts/tailwind3.4.16.js"></script>
    <link rel="stylesheet" href="/static/styles/home.css">
    <script>
        tailwind.config = {
          darkMode: 'class',
          theme: {
            extend: {
              colors: {
                primary: {
                  DEFAULT: '#3B82F6',
                  '50': '#EBF2FF',
                  '100': '#D6E4FF',
                  '200': '#ADCAFD',
                  '300': '#85B0FC',
                  '400': '#5C96FB',
                  '500': '#3B82F6',
                  '600': '#0B61EF',
                  '700': '#084BBD',
                  '800': '#06368A',
                  '900': '#042158'
                },
              }
            }
          }
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
    <div class="min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <%- include('../../../partials/admin/adminPanelNav') %>
        
        <!-- Sidebar -->
        <%- include('../../../partials/admin/adminPanelSidebar') %>
        


        <!-- Main Content -->
        <main class="flex-1 items-center justify-center p-4 md:p-6 md:<%= language === 'ar' ? 'mr-64' : 'ml-64' %>">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
                <div class="bg-white dark:bg-gray-800 shadow-xl rounded-lg">
                    <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
                        <h2 class="text-2xl font-bold leading-tight text-gray-900 dark:text-white">
                            <%= adminHome.page_title %>
                        </h2>
                        <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">
                            <%= adminHome.page_description %>
                        </p>
                    </div>
            
                    <div class="flex flex-col gap-6 p-6">
                        <!-- Marquee Management -->
                        <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-6 shadow-md">
                            <h3 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">
                                <%= adminHome.marquee_management.title %>
                            </h3>
            
                            <div class="space-y-4">
                                <!-- Current Marquee -->
                                <div class="bg-white dark:bg-gray-700 p-4 rounded-lg">
                                    <h4 class="font-medium mb-2 text-gray-700 dark:text-gray-200"><%= adminHome.marquee_management.current_marquee %></h4>
                                    <p id="marquee" class="text-gray-600 dark:text-gray-300 italic mb-3">
                                        <%= adminHome.marquee_management.current_marquee_placeholder %>
                                    </p>
                                    <textarea id="marquee-text" placeholder="<%= adminHome.marquee_management.update_marquee %>" rows="5" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500 resize-none"></textarea>
                                    <button type="button" id="marquee-button" class="w-full mt-2 bg-primary-600 text-white py-2 rounded-md hover:bg-primary-700 transition">
                                        <%= adminHome.marquee_management.update_marquee %>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Image Slider Management -->
                        <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-6 shadow-md">
                            <h3 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">
                                <%= adminHome.image_slider_management.title %>
                            </h3>
                            <p class="mb-4 max-w-2xl text-sm text-gray-500 dark:text-gray-400">
                                <%= adminHome.image_slider_management.image_slider_description %>
                            </p>
                            <div class="space-y-4">
                                <!-- Add New Slide -->
                                <div class="bg-white dark:bg-gray-700 p-4 rounded-lg shadow">
                                    <h4 class="font-medium mb-2 text-gray-700 dark:text-gray-200"><%= adminHome.image_slider_management.add_new_slide %></h4>
                                    <form id="add-slide-form" class="space-y-3" enctype="multipart/form-data">
                                        <input type="file" name="sliderImage" accept="image/*" class="w-full text-sm text-gray-500 dark:text-gray-300
                                            file:mr-4 file:py-2 file:px-4
                                            file:rounded-full file:border-0
                                            file:text-sm file:font-semibold
                                            file:bg-primary-50 file:text-primary-700
                                            hover:file:bg-primary-100
                                            dark:file:bg-gray-600 dark:file:text-white">
                                        
                                        <input type="text" name="title" placeholder="<%= adminHome.image_slider_management.slide_title %>" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500" required>
                                        
                                        <input type="text" name="description" placeholder="<%= adminHome.image_slider_management.slide_description %>" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500" required>
                                        
                                        <input type="text" name="altText" placeholder="<%= adminHome.image_slider_management.slide_image_alt %>" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500" required>
                                        
                                        <button type="submit" class="w-full bg-primary-600 text-white py-2 rounded-md hover:bg-primary-700 transition"><%= adminHome.image_slider_management.add_new_slide %></button>
                                    </form>
                                </div>
            
                                <!-- Existing Slides -->
                                <div class="space-y-2">
                                    <h4 class="font-medium text-gray-700 dark:text-gray-200"><%= adminHome.image_slider_management.current_slides %></h4>
                                    <div id="slides-container" class="space-y-2">
                                        <!-- Slides will be loaded dynamically here -->
                                        <div class="text-center py-4 text-gray-500 dark:text-gray-400">
                                            <%= adminHome.image_slider_management.loading_slides %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
            
                    </div>
                </div>
            </div>
        </main>
    </div>    
    <%- include('../../../partials/footer') %>
    </div>
<script src="/static/js/sweetalert2.js"></script>
<script src="/static/js/custom.js"></script>
<script>
    // Toggle dark mode
    const themeToggleBtn = document.getElementById('theme-toggle');
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });

    // Check for saved theme preference
    if (localStorage.getItem('theme') === 'dark' || 
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    // Toggle sidebar on mobile
    const toggleSidebarBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');
    toggleSidebarBtn.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
      sidebar.classList.toggle('translate-x-0');
    });

    // Toggle language dropdown
    const languageDropdownBtn = document.getElementById('language-dropdown-btn');
    const languageDropdown = document.getElementById('language-dropdown');
    languageDropdownBtn.addEventListener('click', () => {
      languageDropdown.classList.toggle('hidden');
    });
    
    // User menu toggle
    const userMenuBtn = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    userMenuBtn.addEventListener('click', () => {
      userMenu.classList.toggle('hidden');
    });
    
    // Close user menu when clicking outside
    document.addEventListener('click', (event) => {
      if (!userMenuBtn.contains(event.target) && !userMenu.contains(event.target)) {
        userMenu.classList.add('hidden');
      }
    });

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // Fetch user profile information
            const response = await fetch('/app/profile');
            
            if (!response.ok) {
                throw new Error('Failed to fetch user profile');
            }

            const userData = await response.json();

            // Update user menu details
            const userNameElement = document.querySelector('#user-menu .text-sm.font-medium');
            const userEmailElement = document.querySelector('#user-menu .text-xs.text-gray-500');
            const sidebarNameElement = document.querySelector('#user-profile p.font-medium');
            const sidebarRoleElement = document.querySelector('#user-profile p.text-xs');

            if (userNameElement) {
                userNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (userEmailElement) {
                userEmailElement.textContent = userData.email || 'user@example.com';
            }

            if (sidebarNameElement) {
                sidebarNameElement.textContent = userData.firstName 
                    ? `${userData.firstName} ${userData.lastName || ''}`.trim() 
                    : 'User';
            }

            if (sidebarRoleElement) {
                sidebarRoleElement.textContent = userData.role || 'Account';
            }

        } catch (error) {
            console.error('Error fetching user profile:', error);
            // Optionally, show a user-friendly error message
        }

        // User menu toggle functionality
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        userMenuButton.addEventListener('click', () => {
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (event) => {
            if (!userMenuButton.contains(event.target) && !userMenu.contains(event.target)) {
                userMenu.classList.add('hidden');
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = document.getElementById('user-menu');

        // Toggle dropdown visibility
        userMenuButton.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevent event from bubbling
            userMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!userMenu.classList.contains('hidden') && 
                !userMenu.contains(e.target) && 
                e.target !== userMenuButton) {
                userMenu.classList.add('hidden');
            }
        });


        const marqueeButton = document.getElementById('marquee-button');
        if (marqueeButton) {
            marqueeButton.addEventListener('click', async () => {
                const marqueeText = document.getElementById('marquee-text').value;
                try {
                    const response = await fetch('/app/admin/panel/home/update-marquee', {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ marqueeText })
                    });
                    if (!response.ok) {
                        throw new Error('Failed to update marquee text');
                    }
                    const data = await response.json();
                    if (data.success) {
                        // Update the displayed marquee text immediately
                        const marqueeDisplay = document.getElementById('marquee');
                        if (marqueeDisplay) {
                            marqueeDisplay.textContent = marqueeText;
                        }
                        successAlert('Marquee text updated successfully');
                    } else {
                        errorAlert('Failed to update marquee text');
                    }
                } catch (error) {
                    console.error('Error updating marquee text:', error);
                    errorAlert('Failed to update marquee text');
                }
            });
        }

        const marqueeCurrentText = document.getElementById('marquee');
        fetch('/static/data/marqueeData.json')
        .then(response => response.json())
        .then(data => {
            marqueeCurrentText.textContent = data.marqueeText;
        })
        .catch(error => {
            console.error('Error fetching marquee text:', error);
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', async () => {
        // Slider Management
        const slidesContainer = document.getElementById('slides-container');
        const addSlideForm = document.getElementById('add-slide-form');

        // Load slides
        const loadSlides = async () => {
            try {
                const response = await fetch('/app/admin/panel/home/slider');
                if (!response.ok) {
                    throw new Error('Failed to fetch slider data');
                }
                
                const data = await response.json();
                
                if (data.success && data.data) {
                    slidesContainer.innerHTML = '';
                    
                    if (data.data.length === 0) {
                        slidesContainer.innerHTML = `
                            <div class="text-center py-4 text-gray-500 dark:text-gray-400">
                                No slides available. Add your first slide!
                            </div>
                        `;
                        return;
                    }
                    
                    data.data.forEach(slide => {
                        const slideElement = document.createElement('div');
                        slideElement.className = 'bg-white dark:bg-gray-700 p-4 rounded-lg flex flex-col md:flex-row items-start md:items-center justify-between';
                        slideElement.innerHTML = `
                            <div class="flex flex-col md:flex-row items-start md:items-center space-y-2 md:space-y-0 md:space-x-4 md:<%= language === 'ar' ? 'space-x-reverse' : '' %> mb-3 md:mb-0">
                                <img src="${slide.imageUrl}" alt="${slide.altText}" class="w-20 h-20 object-cover rounded">
                                <div class="<%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                    <h5 class="font-medium text-gray-700 dark:text-gray-200">${slide.title}</h5>
                                    <p class="text-sm text-gray-500 dark:text-gray-400">${slide.description}</p>
                                </div>
                            </div>
                            <div class="space-x-2 flex <%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                <button class="edit-slide-btn text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 px-3 py-1 border border-blue-600 dark:border-blue-400 rounded" data-id="${slide.id}"><%= adminHome.image_slider_management.slide_actions.edit %></button>
                                <button class="delete-slide-btn text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 px-3 py-1 border border-red-600 dark:border-red-400 rounded" data-id="${slide.id}"><%= adminHome.image_slider_management.slide_actions.delete %></button>
                            </div>
                        `;
                        slidesContainer.appendChild(slideElement);
                        
                        // Add event listeners for edit and delete buttons
                        const editBtn = slideElement.querySelector('.edit-slide-btn');
                        const deleteBtn = slideElement.querySelector('.delete-slide-btn');
                        
                        editBtn.addEventListener('click', () => {
                            // Create edit form
                            const currentContent = slideElement.innerHTML;
                            slideElement.innerHTML = `
                                <form class="edit-slide-form w-full space-y-3" data-id="${slide.id}">
                                    <div class="flex items-center space-x-4 mb-3">
                                        <img src="${slide.imageUrl}" alt="${slide.altText}" class="w-20 h-20 object-cover rounded">
                                        <input type="file" name="sliderImage" accept="image/*" class="text-sm text-gray-500 dark:text-gray-300
                                            file:mr-4 file:py-2 file:px-4
                                            file:rounded-full file:border-0
                                            file:text-sm file:font-semibold
                                            file:bg-primary-50 file:text-primary-700
                                            hover:file:bg-primary-100
                                            dark:file:bg-gray-600 dark:file:text-white">
                                    </div>
                                    <input type="text" name="title" value="${slide.title}" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500">
                                    <input type="text" name="description" value="${slide.description}" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500">
                                    <input type="text" name="altText" value="${slide.altText}" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500">
                                    <div class="flex space-x-2 <%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                        <button type="submit" class="bg-primary-600 text-white py-2 px-4 rounded-md hover:bg-primary-700 transition"><%= adminHome.image_slider_management.slide_actions.save %></button>
                                        <button type="button" class="cancel-edit-btn bg-gray-300 text-gray-800 dark:bg-gray-600 dark:text-white py-2 px-4 rounded-md hover:bg-gray-400 dark:hover:bg-gray-500 transition"><%= adminHome.image_slider_management.slide_actions.cancel %></button>
                                    </div>
                                </form>
                            `;
                            
                            // Add event listener for cancel button
                            const cancelBtn = slideElement.querySelector('.cancel-edit-btn');
                            cancelBtn.addEventListener('click', () => {
                                slideElement.innerHTML = currentContent;
                                
                                // Re-add event listeners after restoring content
                                const newEditBtn = slideElement.querySelector('.edit-slide-btn');
                                const newDeleteBtn = slideElement.querySelector('.delete-slide-btn');
                                
                                newEditBtn.addEventListener('click', () => editBtn.click());
                                newDeleteBtn.addEventListener('click', () => deleteBtn.click());
                            });
                            
                            // Add event listener for form submission
                            const editForm = slideElement.querySelector('.edit-slide-form');
                            editForm.addEventListener('submit', async (e) => {
                                e.preventDefault();
                                
                                const formData = new FormData(editForm);
                                formData.append('id', slide.id);
                                
                                try {
                                    const response = await fetch('/app/admin/panel/home/update-slider', {
                                        method: 'PUT',
                                        body: formData
                                    });
                                    
                                    if (!response.ok) {
                                        throw new Error('Failed to update slide');
                                    }
                                    
                                    const result = await response.json();
                                    
                                    if (result.success) {
                                        successAlert('Slide updated successfully');
                                        loadSlides(); // Reload slides
                                    } else {
                                        errorAlert(result.message || 'Failed to update slide');
                                    }
                                } catch (error) {
                                    console.error('Error updating slide:', error);
                                    errorAlert('Failed to update slide');
                                }
                            });
                        });
                        
                        deleteBtn.addEventListener('click', async () => {
                            const deleteSlider = await confirmAlert('Are you sure you want to delete this slide?')
                            if (deleteSlider.isConfirmed) {
                                try {
                                    const response = await fetch(`/app/admin/panel/home/slider/${slide.id}`, {
                                        method: 'DELETE'
                                    });
                                    
                                    if (!response.ok) {
                                        throw new Error('Failed to delete slide');
                                    }
                                    
                                    const result = await response.json();
                                    
                                    if (result.success) {
                                        successAlert('Slide deleted successfully');
                                        loadSlides(); // Reload slides
                                    } else {
                                        errorAlert(result.message || 'Failed to delete slide');
                                    }
                                } catch (error) {
                                    console.error('Error deleting slide:', error);
                                    errorAlert('Failed to delete slide');
                                }
                            }
                        });
                    });
                } else {
                    slidesContainer.innerHTML = `
                        <div class="text-center py-4 text-gray-500 dark:text-gray-400">
                            Failed to load slides. Please try again.
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading slides:', error);
                slidesContainer.innerHTML = `
                    <div class="text-center py-4 text-gray-500 dark:text-gray-400">
                        Failed to load slides. Please try again.
                    </div>
                `;
            }
        };
        
        // Load slides on page load
        loadSlides();
        
        // Add event listener for adding new slides
        if (addSlideForm) {
            addSlideForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const formData = new FormData(addSlideForm);
                
                try {
                    const response = await fetch('/app/admin/panel/home/slider', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (!response.ok) {
                        throw new Error('Failed to add slide');
                    }
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        successAlert('Slide added successfully');
                        addSlideForm.reset();
                        loadSlides(); // Reload slides
                    } else {
                        errorAlert(result.message || 'Failed to add slide');
                    }
                } catch (error) {
                    console.error('Error adding slide:', error);
                    errorAlert('Failed to add slide');
                }
            });
        }
    });
</script>
<script src="/static/js/profile.js"></script>
<script src="/static/js/language.js"></script>
<script src="/static/js/notification-bell.js"></script>
</body>
</html>
