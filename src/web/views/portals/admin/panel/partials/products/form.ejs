<!-- Product Form Modal -->
<div id="product-form-modal" class="fixed animate__animated animate__fadeIn inset-0 bg-gray-600 backdrop-blur-sm bg-gray-900/20 dark:backdrop-blur-sm dark:bg-gray-900/20 hidden overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4 text-center">
        <div class="relative w-full max-w-2xl transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 px-4 pb-4 pt-5 <%= language === 'ar' ? 'text-right' : 'text-left' %> shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-2xl sm:p-6">
            <div class="absolute <%= language === 'ar' ? 'left-0 pl-4' : 'right-0 pr-4' %> top-0 hidden pt-4 sm:block">
                <button type="button" 
                    class="rounded-md bg-white dark:bg-gray-800 text-gray-400 hover:text-gray-500 dark:hover:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
                    onclick="closeProductForm()">
                    <span class="sr-only"><%= common.close %></span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="sm:flex sm:items-start sm:justify-between">
                <div class="mt-3 text-center sm:mt-0 sm:<%= language === 'ar' ? 'text-right' : 'text-left' %> w-full">
                    <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white" id="modal-title">
                        <%= productForm.addTitle %>
                    </h3>
                    <div class="mt-2">
                        <form id="product-form" class="space-y-6" data-action="" data-product-id="">
                            <div class="grid grid-cols-1 gap-6 sm:grid-cols-6">
                                <!-- Category -->
                                <div class="sm:col-span-6">
                                    <label for="categoryId" class="block my-2 text-sm font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.category %>
                                    </label>
                                    <select id="categoryId" name="categoryId" 
                                        class="mt-1 block w-full p-3 dark:bg-gray-700 rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500  dark:border-gray-700 dark:text-white">
                                        <% categories.forEach(category => { %>
                                        <option value="<%= category.id %>">
                                            <%= category.name %>
                                        </option>
                                        <% }) %>
                                    </select>
                                </div>

                                <!-- Name -->
                                <div class="sm:col-span-6">
                                    <label for="name" class="block text-sm my-2 font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.name %>
                                    </label>
                                    <input type="text" name="name" id="name" 
                                        class="mt-1 block w-full rounded-md p-3 bg-gray-100 border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-700 dark:border-gray-700 dark:text-white"
                                        required>
                                </div>

                                <!-- Price and Min Units -->
                                <div class="sm:col-span-6 grid grid-cols-2 gap-4">
                                    <!-- Price in USD -->
                                    <div>
                                        <label for="price" class="block text-sm my-2 font-medium text-gray-700 dark:text-gray-400">
                                            <%= productForm.fields.price %>
                                        </label>
                                        <input type="number" step="0.001" min="0" name="price" id="price" 
                                            class="mt-1 block w-full rounded-md p-3 bg-gray-100 border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-700 dark:border-gray-700 dark:text-white"
                                            required>
                                    </div>

                                    <!-- Min Units -->
                                    <div>
                                        <label for="minUnits" class="block text-sm my-2 font-medium text-gray-700 dark:text-gray-400">
                                            <%= productForm.fields.minUnits %>
                                        </label>
                                        <input type="number" min="1" name="minUnits" id="minUnits" value="1"
                                            class="mt-1 block w-full rounded-md p-3 bg-gray-100 border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-700 dark:border-gray-700 dark:text-white"
                                            required>
                                    </div>
                                </div>
                                <!-- Price in JOD -->
                                <div class="sm:col-span-3">
                                    <label for="price_jod" class="block text-sm my-2 font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.price_jod %>
                                    </label>
                                    <input type="number" step="0.001" min="0" name="price_jod" id="price_jod" 
                                        class="mt-1 block w-full rounded-md p-3 bg-gray-100 border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-700 dark:border-gray-700 dark:text-white"
                                        required>
                                </div>

                                <!-- Is Available -->
                                <div class="sm:col-span-6">
                                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.is_available %>
                                    </label>
                                    <div class="mt-2">
                                        <label class="inline-flex items-center">
                                            <input type="checkbox" name="isAvailable" id="isAvailable"
                                                class="form-checkbox h-5 w-5 mx-2 text-primary-600 bg-gray-100 dark:text-primary-500">
                                            <span class="ml-2 text-gray-700 dark:text-gray-400">
                                                <%= productForm.labels.is_available %>
                                            </span>
                                        </label>
                                    </div>
                                </div>

                                <!-- Image -->
                                <div class="sm:col-span-6">
                                    <label for="image" class="block text-sm my-2 font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.image %>
                                    </label>
                                    <div class="mt-1 flex justify-center rounded-md border-2 border-dashed border-gray-300 px-6 pt-5 pb-6 dark:border-gray-700">
                                        <div class="space-y-1 text-center">
                                            <div class="h-10 w-10 mx-auto mb-2">
                                                <svg id="upload-svg" class="h-12 w-12 text-gray-400 dark:text-gray-600" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                                                    <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </div>
                                            <div id="file-info" class="text-sm text-gray-600 dark:text-gray-300 mb-2 hidden"></div>
                                            <div class="flex justify-center text-sm text-gray-600 dark:text-gray-400">
                                                <label for="image" class="relative cursor-pointer bg-white dark:bg-gray-800 rounded-md font-medium text-primary-600 dark:text-primary-500 hover:text-primary-500 dark:hover:text-primary-400 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-primary-500 dark:focus-within:ring-offset-gray-800">
                                                    <span><%= productForm.fields.img_upload_file %></span>
                                                    <input id="image" name="image" type="file" class="sr-only" accept="image/*">
                                                </label>
                                            </div>
                                            <p class="text-xs text-gray-500 dark:text-gray-400"><%= productForm.fields.img_formats %></p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Dynamic Specifications Section -->
                                <div class="sm:col-span-6 border-t border-gray-200 dark:border-gray-700 pt-6">
                                    <label class="block text-sm font-medium text-gray-900 dark:text-white mb-2">
                                        <%= productForm.fields.dialog_forms.main_label %>
                                    </label>
                                    <div id="dynamic-fields-container" class="space-y-3">
                                        <!-- New fields are injected here by JavaScript -->
                                    </div>
                                    <div class="flex items-center gap-4 mt-4">
                                        <button type="button" onclick="addNewSpecification()" class="flex items-center justify-center gap-2 flex-1 bg-blue-50 dark:bg-blue-900/50 text-blue-600 dark:text-blue-300 font-bold py-2 px-4 rounded-lg focus:outline-none focus:shadow-outline transition duration-300 hover:bg-blue-100 dark:hover:bg-blue-900">
                                            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                                            <%= productForm.fields.dialog_forms.add_field %>
                                        </button>
                                        <button type="button" onclick="deleteLastSpecification()" class="flex items-center justify-center gap-2 flex-1 bg-red-50 dark:bg-red-900/50 text-red-600 dark:text-red-300 font-bold py-2 px-4 rounded-lg focus:outline-none focus:shadow-outline transition duration-300 hover:bg-red-100 dark:hover:bg-red-900">
                                           <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 10a1 1 0 011-1h8a1 1 0 110 2H6a1 1 0 01-1-1z" clip-rule="evenodd" /></svg>
                                            <%= productForm.fields.dialog_forms.delete_field %>
                                        </button>
                                    </div>
                                </div>

                                <!-- Dialog Description -->
                                <div class="sm:col-span-6">
                                    <label for="dialogDescription" class="block my-2 text-sm font-medium text-gray-700 dark:text-gray-400">
                                        <%= productForm.fields.dialog_description %>
                                    </label>
                                    <textarea id="dialogDescription" name="dialogDescription" rows="3"
                                        class="mt-1 block w-full p-3 rounded-md bg-gray-100 border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-700 dark:border-gray-700 dark:text-white"
                                        placeholder="<%= productForm.placeholders.dialog_description %>"></textarea>
                                </div>
                            </div>

                            <div class="flex justify-end space-x-3">
                                <button type="button" onclick="closeProductForm()"
                                    class="inline-flex justify-center rounded-md border border-transparent bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-offset-gray-800">
                                    <%= common.cancel %>
                                </button>
                                <button type="submit"
                                    class="inline-flex justify-center rounded-md border border-transparent bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:bg-primary-500 dark:hover:bg-primary-600 dark:focus:ring-offset-gray-800">
                                    <%= common.save %>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Success Notification -->
<div id="successNotification" class="fixed bottom-4 <%= language === 'ar' ? 'left-4' : 'right-4' %> bg-green-500 text-white px-4 py-2 rounded-md shadow-lg hidden">
    <div class="flex items-center">
        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span id="successMessage"></span>
    </div>
</div>