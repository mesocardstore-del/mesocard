<!-- Header and Actions -->
<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-800 dark:text-white"><%= pageTitle %></h1>
    <div class="flex flex-row items-center gap-2">
        <div>
            <button id="notify-btn" class="flex items-center mt-2 md:mt-0 px-4 py-2 text-white bg-yellow-400 dark:bg-yellow-500 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 transition-colors" type="button">
                <!-- Bell SVG Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 <%= language === 'ar' ? 'ml-2' :'mr-2' %>">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                </svg>
                <%= userForm.notification %>
            </button>
        </div>
        <div>
            <button id="addUserBtn" class="mt-2 md:mt-0 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                + <%= userForm.addTitle %>
            </button>
        </div>
    </div>
</div>

<!-- Search and Filters -->
<div class="mb-6 dark:text-white">
    <div class="flex flex-col md:flex-row gap-4">
        <!-- Search Input -->
        <div class="relative flex-1">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
            </div>
            <input type="text" id="searchUsers" class="block w-full pl-10 pr-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md leading-5 bg-white dark:bg-gray-700 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="<%= usersTable.filters.search.placeholder %>">
        </div>
        
        <!-- Role Filter -->
        <div class="w-full md:w-48">
            <select id="roleFilter" class="block w-full pl-3 pr-10 py-2 text-base border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md bg-white dark:bg-gray-700">
                <option value=""><%= usersTable.filters.role.all %></option>
                <option value="admin"><%= usersTable.filters.role.admin %></option>
                <option value="user"><%= usersTable.filters.role.user %></option>
            </select>
        </div>
        
        <!-- Status Filter -->
        <div class="w-full md:w-48">
            <select id="statusFilter" class="block w-full pl-3 pr-10 py-2 text-base border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md bg-white dark:bg-gray-700">
                <option value=""><%= usersTable.filters.status.all %></option>
                <option value="active"><%= usersTable.filters.status.active %></option>
                <option value="pending"><%= usersTable.filters.status.pending %></option>
                <option value="locked"><%= usersTable.filters.status.locked %></option>
            </select>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
                <tr>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.name %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.email %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.phone %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.role %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.balance %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.status %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.lastLogin %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.registered %></th>
                    <th scope="col" class="px-6 py-3 <%= language === 'ar' ? 'text-left' : 'text-right' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= usersTable.columns.actions %></th>
                </tr>
            </thead>
            <tbody id="usersTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <!-- Loading State -->
                <tr>
                    <td colspan="9" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">
                        <div class="flex justify-center">
                            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <%= usersTable.loading %>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="bg-white dark:bg-gray-800 px-4 py-3 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 sm:px-6">
        <!-- Mobile Pagination -->
        <div id="mobilePagination" class="flex-1 flex justify-between sm:hidden">
            <button id="prevPageMobile" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300">
                <%= pagination.previous %>
            </button>
            <button id="nextPageMobile" class="<%= language === 'ar' ? 'mr-3' : 'ml-3' %> relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300">
                <%= pagination.next %>
            </button>
        </div>
        
        <!-- Desktop Pagination -->
        <div id="desktopPagination" class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <!-- Pagination Info -->
            <div id="paginationInfo">
                <p class="text-sm text-gray-700 dark:text-gray-300">
                    <%= pagination.showing %> <span id="startItem" class="font-medium">1</span> <%= pagination.to %> 
                    <span id="endItem" class="font-medium">10</span> <%= pagination.of %> 
                    <span id="totalItems" class="font-medium">0</span> <%= pagination.users %>
                </p>
            </div>
            
            <!-- Pagination Controls -->
            <nav id="paginationControls" class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <button id="prevPage" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300">
                    <span class="sr-only"><%= pagination.previous %></span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    </button>
                    <div id="pageNumbers" class="flex">
                        <!-- Page numbers will be inserted here by JavaScript -->
                    </div>
                    <button id="nextPage" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300">
                        <span class="sr-only"><%= pagination.next %></span>
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                    </button>
                </nav>
            </div>
        </div>
    </div>
</div>
