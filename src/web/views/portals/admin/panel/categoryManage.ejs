<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= adminCategory.title %>
    </title>
    <script src="/static/scripts/tailwind3.4.16.js"></script>
    <link rel="stylesheet" href="/static/styles/home.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            DEFAULT: '#3B82F6',
                            '50': '#EBF2FF',
                            '100': '#D6E4FF',
                            '200': '#ADCAFD',
                            '300': '#85B0FC',
                            '400': '#5C96FB',
                            '500': '#3B82F6',
                            '600': '#0B61EF',
                            '700': '#084BBD',
                            '800': '#06368A',
                            '900': '#042158'
                        },
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 dark:bg-gray-900">
    <div class="min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <%- include('../../../partials/admin/adminPanelNav') %>

            <!-- Sidebar -->
            <%- include('../../../partials/admin/adminPanelSidebar') %>

                <!-- Main Content -->
                <main
                    class="flex-1 items-center justify-center p-4 md:p-6 md:<%= language === 'ar' ? 'mr-64' : 'ml-64' %>">
                    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        <div class="bg-white dark:bg-gray-800 shadow-xl rounded-lg">
                            <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
                                <h2 class="text-2xl font-bold leading-tight text-gray-900 dark:text-white">
                                    <%= adminCategory.page_title %>
                                </h2>
                                <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">
                                    <%= adminCategory.page_description %>
                                </p>
                            </div>

                            <div class="flex flex-col gap-6 p-6">
                                <!-- Add/Edit Category Form -->
                                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-6 shadow-md">
                                    <h3 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white"
                                        id="form-title">
                                        <%= adminCategory.form.title_add %>
                                    </h3>

                                    <div class="space-y-4">
                                        <form id="category-form" class="space-y-3">
                                            <input type="hidden" id="category-id" name="id">

                                            <div class="form-group">
                                                <label for="category-name"
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                                    <%= adminCategory.form.name %>
                                                </label>
                                                <input type="text" id="category-name" name="name"
                                                class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500"
                                                required>
                                            </div>
                                            <div class="form-group">
                                                <label for="category-name-ar" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= adminCategory.form.name_ar %></label>
                                                <input type="text" id="category-name-ar" name="nameAr" class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500" required>
                                            </div>

                                            <div class="form-group">
                                                <label for="category-description"
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                                    <%= adminCategory.form.description %>
                                                </label>
                                                <textarea id="category-description" name="description" rows="3"
                                                    class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500 resize-none"></textarea>
                                            </div>

                                            <div class="form-group">
                                                <label for="parent-category"
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                                    <%= adminCategory.form.parent %>
                                                </label>
                                                <select id="parent-category" name="parentId"
                                                    class="w-full px-3 py-2 border rounded-md text-gray-900 dark:text-white bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 focus:ring-primary-500 focus:border-primary-500">
                                                    <option value="">
                                                        <%= adminCategory.form.select_parent %>
                                                    </option>
                                                    <!-- Categories will be loaded dynamically here -->
                                                </select>
                                            </div>


                                            <div class="form-group">
                                                <label for="category-image"
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                                    <%= adminCategory.form.category_image %>
                                                </label>
                                                <input type="file" id="category-image" name="categoryImage"
                                                    accept="image/*" class="w-full text-sm text-gray-500 dark:text-gray-300
                                            file:mr-4 file:py-2 file:px-4
                                            file:rounded-full file:border-0
                                            file:text-sm file:font-semibold
                                            file:bg-primary-50 file:text-primary-700
                                            hover:file:bg-primary-100
                                            dark:file:bg-gray-600 dark:file:text-white">
                                            </div>

                                            <div class="form-group">
                                                <label for="category-active"
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                                    <%= adminCategory.form.status.label %>
                                                </label>
                                                <div
                                                    class="flex items-center space-x-2 <%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                                    <input type="checkbox" id="category-active" name="isActive"
                                                        class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded"
                                                        checked>
                                                    <label for="category-active"
                                                        class="text-sm text-gray-700 dark:text-gray-300">
                                                        <%= adminCategory.form.status.active %>
                                                    </label>
                                                </div>
                                            </div>

                                            <div
                                                class="flex space-x-2 pt-3 <%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                                <button type="submit" id="save-category-btn"
                                                    class="px-4 py-2 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition">
                                                    <%= adminCategory.actions.save %>
                                                </button>
                                                <button type="button" id="cancel-edit-btn"
                                                    class="px-4 py-2 bg-gray-300 text-gray-800 dark:bg-gray-600 dark:text-white rounded-md hover:bg-gray-400 dark:hover:bg-gray-500 transition hidden">
                                                    <%= adminCategory.actions.cancel %>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <!-- Categories List -->
                                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-6 shadow-md">
                                    <div class="flex justify-between items-center mb-4">
                                        <h3 class="text-xl font-semibold text-gray-800 dark:text-white">
                                            <%= adminCategory.table.title %>
                                        </h3>
                                        <div class="flex space-x-2">
                                            <button id="refresh-categories-btn"
                                                class="px-3 py-1 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-md hover:bg-gray-300 dark:hover:bg-gray-600 transition flex items-center space-x-1 <%= language === 'ar' ? 'space-x-reverse' : '' %>">
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                    class="h-4 w-4 <%= language === 'ar' ? 'ml-1' : 'mr-1' %>"
                                                    fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                                </svg>
                                                <%= adminCategory.table.refresh %>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="overflow-x-auto">
                                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                                            <thead class="bg-gray-100 dark:bg-gray-800">
                                                <tr>
                                                    <th scope="col"
                                                        class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                                        <%= adminCategory.table.columns.orderId %>
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                                        <%= adminCategory.table.columns.name %>
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                                        <%= adminCategory.table.columns.parent %>
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 <%= language === 'ar' ? 'text-right' : 'text-left' %> text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                                        <%= adminCategory.table.columns.status %>
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                                        <%= adminCategory.table.columns.actions %>
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="categories-table-body"
                                                class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                                                <!-- Categories will be loaded dynamically here -->
                                                <tr>
                                                    <td colspan="4"
                                                        class="px-6 py-4 text-center text-sm text-gray-500 dark:text-gray-400">
                                                        <%= adminCategory.table.loading %>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
    </div>
    <%- include('../../../partials/footer') %>
        </div>

        <script src="/static/js/sweetalert2.js"></script>
        <script src="/static/js/custom.js"></script>

        <script>
            // Toggle dark mode
            const themeToggleBtn = document.getElementById('theme-toggle');
            themeToggleBtn.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
            });

            // Check for saved theme preference
            if (localStorage.getItem('theme') === 'dark' ||
                (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // Toggle sidebar on mobile
            const toggleSidebarBtn = document.getElementById('toggle-sidebar');
            const sidebar = document.getElementById('sidebar');
            toggleSidebarBtn.addEventListener('click', () => {
                sidebar.classList.toggle('-translate-x-full');
                sidebar.classList.toggle('translate-x-0');
            });

            // Toggle language dropdown
            const languageDropdownBtn = document.getElementById('language-dropdown-btn');
            const languageDropdown = document.getElementById('language-dropdown');
            languageDropdownBtn.addEventListener('click', () => {
                languageDropdown.classList.toggle('hidden');
            });


            // User menu toggle
            const userMenuBtn = document.getElementById('user-menu-button');
            const userMenu = document.getElementById('user-menu');
            userMenuBtn.addEventListener('click', () => {
                userMenu.classList.toggle('hidden');
            });

            // Close user menu when clicking outside
            document.addEventListener('click', (event) => {
                if (!userMenuBtn.contains(event.target) && !userMenu.contains(event.target)) {
                    userMenu.classList.add('hidden');
                }
            });

            // Category management functionality
            document.addEventListener('DOMContentLoaded', async () => {
                const categoryForm = document.getElementById('category-form');
                const formTitle = document.getElementById('form-title');
                const categoryIdInput = document.getElementById('category-id');
                const categoryNameInput = document.getElementById('category-name');
                const categoryNameArInput = document.getElementById('category-name-ar');
                const categoryDescriptionInput = document.getElementById('category-description');
                const parentCategorySelect = document.getElementById('parent-category');
                const categoryActiveCheckbox = document.getElementById('category-active');
                const saveCategoryBtn = document.getElementById('save-category-btn');
                const cancelEditBtn = document.getElementById('cancel-edit-btn');
                const refreshCategoriesBtn = document.getElementById('refresh-categories-btn');
                const categoriesTableBody = document.getElementById('categories-table-body');

                let categories = [];
                let isEditing = false;

                // Load categories
                const loadCategories = async () => {
                    try {
                        const response = await fetch('/api/v1/admin/manage/category');
                        if (!response.ok) {
                            throw new Error('Failed to fetch categories');
                        }

                        const data = await response.json();

                        if (data.success) {
                            categories = data.results || [];
                            renderCategories();
                            populateParentCategoryDropdown();
                        } else {
                            throw new Error(data.message || 'Failed to fetch categories');
                        }
                    } catch (error) {
                        console.error('Error loading categories:', error);
                        categoriesTableBody.innerHTML = `
                    <tr>
                        <td colspan="4" class="px-6 py-4 text-center text-sm text-red-500">
                            Error loading categories. Please try again.
                        </td>
                    </tr>
                `;
                    }
                };

                // Render categories in the table
                const renderCategories = () => {
                    if (categories.length === 0) {
                        categoriesTableBody.innerHTML = `
                    <tr>
                        <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500 dark:text-gray-400">
                            No categories found. Create your first category!
                        </td>
                    </tr>
                `;
                        return;
                    }

                    categoriesTableBody.innerHTML = '';

                    categories.forEach(category => {
                        const parentCategory = categories.find(c => c.id === category.parentId);
                        const parentName = parentCategory ? parentCategory.name : '-';

                        const row = document.createElement('tr');
                        row.className = 'hover:bg-gray-50 dark:hover:bg-gray-700';
                        row.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <input type="number" 
                                   value="${category.orderId}" 
                                   onchange="updateCategoryOrder('${category.id}', this.value)"
                                   class="w-16 px-2 py-1 text-sm border rounded-md focus:ring-2 focus:ring-primary-500 dark:bg-gray-800 dark:border-gray-700 dark:text-white"
                                   min="1">
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                        ${category.name}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        ${parentName}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${category.isActive ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'}">
                            ${category.isActive ? '<%= adminCategory.table.active %>' : '<%= adminCategory.table.inactive %> '}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <button class="edit-category-btn text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300 <%= language === 'ar' ? 'ml-3' : 'mr-3' %>" data-id="${category.id}">
                            <%= adminCategory.buttons.edit %>
                        </button>
                        <button class="delete-category-btn text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 <%= language === 'ar' ? 'ml-3' : 'mr-3' %>" data-id="${category.id}">
                            <%= adminCategory.buttons.delete %>
                        </button>
                    </td>
                `;

                        categoriesTableBody.appendChild(row);
                    });

                    // Add event listeners to edit and delete buttons
                    document.querySelectorAll('.edit-category-btn').forEach(button => {
                        button.addEventListener('click', () => editCategory(button.dataset.id));
                    });

                    document.querySelectorAll('.delete-category-btn').forEach(button => {
                        button.addEventListener('click', () => deleteCategory(button.dataset.id));
                    });
                };

                // Populate parent category dropdown
                const populateParentCategoryDropdown = () => {
                    // Clear existing options except the first one
                    const firstOption = parentCategorySelect.options[0];
                    parentCategorySelect.innerHTML = '';
                    parentCategorySelect.appendChild(firstOption);

                    // Add categories as options
                    categories.forEach(category => {
                        const option = document.createElement('option');
                        option.value = category.id;
                        option.textContent = category.name;
                        parentCategorySelect.appendChild(option);
                    });
                };

                // Edit category
                const editCategory = async (id) => {
                    try {
                        const response = await fetch(`/api/v1/admin/manage/category/${id}`);
                        if (!response.ok) {
                            throw new Error('Failed to fetch category details');
                        }

                        const data = await response.json();

                        if (data.success && data.results) {
                            const category = data.results;

                            // Set form to edit mode
                            isEditing = true;
                            formTitle.textContent = '<%= adminCategory.form.title_edit %>';
                            categoryIdInput.value = category.id;
                            categoryNameInput.value = category.name || '';
                            categoryNameArInput.value = category.CategoryTranslations?.[0]?.name || '';
                            categoryDescriptionInput.value = category.CategoryTranslations?.[0]?.description || '';
                            parentCategorySelect.value = category.parentId || '';
                            categoryActiveCheckbox.checked = category.isActive !== false;

                            saveCategoryBtn.textContent = '<%= adminCategory.actions.save %>';
                            cancelEditBtn.classList.remove('hidden');

                            // Scroll to form
                            categoryForm.scrollIntoView({ behavior: 'smooth' });
                        } else {
                            throw new Error(data.message || 'Failed to fetch category details');
                        }
                    } catch (error) {
                        console.error('Error fetching category details:', error);
                        errorAlert('Error fetching category details. Please try again.')
                    }
                };

                window.updateCategoryOrder = async function(productId, newOrder) {
                    try {
                        const response = await fetch(`/api/v1/admin/manage/category/${productId}/order/${newOrder}`, {
                            method: 'PATCH',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                        });
                
                        if (!response.ok) {
                            throw new Error('Failed to update order');
                        }
                        
                        await loadCategories();
                        showSuccess(language === 'ar' ? 'تم تحديث ترتيب القسم بنجاح!' : 'Category order updated successfully!');
                    } catch (error) {
                        console.error('Error updating category order:', error);
                        showError(language === 'ar' ? 'فشل تحديث ترتيب القسم' : 'Failed to update category order');
                    }
                }
    
                // Delete category
                const deleteCategory = async (id) => {

                    const deleteCat = await confirmAlert(text='<%= adminCategory.messages.confirm_delete %>');
                    if (!deleteCat.isConfirmed) {
                        return;
                    }

                    try {
                        const response = await fetch(`/api/v1/admin/manage/category/${id}`, {
                            method: 'DELETE',
                            headers: {
                                'Content-Type': 'application/json'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Failed to delete category');
                        }

                        const data = await response.json();

                        if (data.success) {
                            successAlert('تم حذف القسم');
                            await loadCategories();
                        } else {
                            throw new Error(data.message || 'Failed to delete category');
                        }
                    } catch (error) {
                        console.error('Error deleting category:', error);
                        errorAlert(`Error deleting category: ${error.message}`);
                    }
                };

                // Reset form
                const resetForm = () => {
                    isEditing = false;
                    formTitle.textContent = '<%= adminCategory.form.title_add %>';
                    categoryForm.reset();
                    categoryIdInput.value = '';
                    saveCategoryBtn.textContent = '<%= adminCategory.actions.save %>';
                    cancelEditBtn.classList.add('hidden');
                };

                // Event listeners
                categoryForm.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const formData = new FormData();

                    // Add all form fields to formData
                    formData.append('name', document.getElementById('category-name').value);
                    formData.append('nameAr', document.getElementById('category-name-ar').value);
                    formData.append('description', document.getElementById('category-description').value);
                    formData.append('isActive', document.getElementById('category-active').checked);

                    const parentCategory = document.getElementById('parent-category').value;
                    if (parentCategory) {
                        formData.append('parentId', parentCategory);
                    }

                    // Handle file upload if present
                    const imageInput = document.getElementById('category-image');
                    if (imageInput.files.length > 0) {
                        formData.append('categoryImage', imageInput.files[0]);
                    }

                    try {
                        let url = '/api/v1/admin/manage/category';
                        let method = 'POST';

                        if (isEditing) {
                            url = `/api/v1/admin/manage/category/${categoryIdInput.value}`;
                            method = 'PUT';
                        }

                        const response = await fetch(url, {
                            method,
                            body: formData
                        });

                        if (!response.ok) {
                            const errorData = await response.json().catch(() => ({}));
                            throw new Error(errorData.message || `Failed to ${isEditing ? 'update' : 'create'} category`);
                        }

                        const data = await response.json();

                        if (data.success) {
                            successAlert(`Category ${isEditing ? 'updated' : 'created'} successfully`);
                            resetForm();
                            await loadCategories();
                        } else {
                            throw new Error(data.message || `Failed to ${isEditing ? 'update' : 'create'} category`);
                        }
                    } catch (error) {
                        console.error(`Error ${isEditing ? 'updating' : 'creating'} category:`, error);
                        errorAlert(`Error ${isEditing ? 'updating' : 'creating'} category: ${error.message}`);
                    }
                });

                cancelEditBtn.addEventListener('click', resetForm);

                refreshCategoriesBtn.addEventListener('click', loadCategories);

                // Initial load
                await loadCategories();
            });
        </script>
        <script src="/static/js/profile.js"></script>
        <script src="/static/js/language.js"></script>
        <script src="/static/js/notification-bell.js"></script>
</body>

</html>