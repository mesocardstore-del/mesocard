<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>429 - <%= language === 'ar' ? 'طلبات كثيرة جداً' : 'Too Many Requests' %></title>
    <style>
        :root {
            --bg-light: #f4f4f4;
            --text-dark: #333;
            --accent-purple: #6f42c1;
            --accent-blue: #007bff;
            --card-bg: #ffffff;
            --text-muted: #6c757d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
            padding: 20px;
        }

        .error-container {
            background-color: var(--card-bg);
            border-radius: 10px;
            padding: 40px;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: 1px solid #e0e0e0;
        }

        .error-code {
            font-size: 120px;
            font-weight: bold;
            color: var(--accent-purple);
            margin-bottom: 20px;
        }

        .error-message {
            font-size: 24px;
            margin-bottom: 30px;
            color: var(--text-dark);
        }

        .error-description {
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .retry-info {
            background-color: #f8f9fa;
            border-radius: 5px;
            padding: 15px;
            margin: 20px 0;
            font-size: 14px;
            color: var(--text-muted);
        }

        .countdown {
            font-weight: bold;
            color: var(--accent-purple);
        }

        .actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .btn {
            display: inline-block;
            padding: 10px 20px;
            background-color: var(--accent-blue);
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: background-color 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn:disabled {
            background-color: #6c757d;
            cursor: not-allowed;
        }

        .btn:hover:not(:disabled) {
            background-color: #0056b3;
        }

        .timestamp {
            margin-top: 20px;
            color: var(--text-muted);
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code">429</div>
        <h1 class="error-message"><%= language === 'ar' ? 'طلبات كثيرة جداً' : 'Too Many Requests' %></h1>
        <p class="error-description">
            <%= language === 'ar' 
                ? 'عذراً، لقد تجاوزت الحد المسموح من الطلبات. يرجى الانتظار قليلاً ثم المحاولة مرة أخرى.'
                : 'Sorry, you have made too many requests. Please wait a while before trying again.' 
            %>
        </p>
        
        <div class="retry-info">
            <span id="countdown-text">
                <%= language === 'ar' ? 'يمكنك المحاولة مرة أخري في وقت لاحق' : 'You can try again later' %>
            </span>
        </div>

        <div class="actions">
            <a href="/" class="btn" id="homeBtn">
                <%= language === 'ar' ? 'العودة للصفحة الرئيسية' : 'Back to Home' %>
            </a>
        </div>
        <div class="timestamp" id="errorTimestamp"></div>
    </div>

    <script>
        // Set timestamp
        document.getElementById('errorTimestamp').textContent = 
            '<%= language === "ar" ? "وقت الخطأ: " : "Error occurred at: " %>' + new Date().toLocaleString();
    </script>
</body>
</html>
