<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>400 - <%= language === 'ar' ? 'طلب خاطئ' : 'Bad Request' %></title>
    <style>
        :root {
            --bg-light: #f4f4f4;
            --text-dark: #333;
            --accent-orange: #f0ad4e;
            --accent-blue: #007bff;
            --card-bg: #ffffff;
            --text-muted: #6c757d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
            padding: 20px;
        }

        .error-container {
            background-color: var(--card-bg);
            border-radius: 10px;
            padding: 40px;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: 1px solid #e0e0e0;
        }

        .error-code {
            font-size: 120px;
            font-weight: bold;
            color: var(--accent-orange);
            margin-bottom: 20px;
        }

        .error-message {
            font-size: 24px;
            margin-bottom: 30px;
            color: var(--text-dark);
        }

        .error-description {
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .actions {
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .btn {
            display: inline-block;
            padding: 10px 20px;
            background-color: var(--accent-blue);
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: background-color 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn:hover {
            background-color: #0056b3;
        }

        .timestamp {
            margin-top: 20px;
            color: var(--text-muted);
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code">400</div>
        <h1 class="error-message"><%= language === 'ar' ? 'طلب خاطئ' : 'Bad Request' %></h1>
        <p class="error-description">
            <%= language === 'ar' 
                ? 'عذراً، لا يمكن معالجة الطلب الذي أرسلته. يرجى التحقق من المدخلات والمحاولة مرة أخرى.'
                : 'Sorry, we couldn\'t process your request. Please check your input and try again.' 
            %>
        </p>
        <div class="actions">
            <a href="/" class="btn"><%= language === 'ar' ? 'العودة للصفحة الرئيسية' : 'Back to Home' %></a>
        </div>
        <div class="timestamp" id="errorTimestamp"></div>
    </div>

    <script>
        document.getElementById('errorTimestamp').textContent = 
            '<%= language === "ar" ? "وقت الخطأ: " : "Error occurred at: " %>' + new Date().toLocaleString();
    </script>
</body>
</html>
