<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>401 - <%= language === 'ar' ? 'غير مصرح' : 'Unauthorized' %></title>
    <style>
        :root {
            --bg-light: #f4f4f4;
            --text-dark: #333;
            --accent-red: #d9534f;
            --accent-blue: #007bff;
            --card-bg: #ffffff;
            --text-muted: #6c757d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif, 'Cairo';
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
            padding: 20px;
        }

        .error-container {
            background-color: var(--card-bg);
            border-radius: 10px;
            padding: 40px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: 1px solid #e0e0e0;
        }

        .error-code {
            font-size: 120px;
            font-weight: bold;
            color: var(--accent-red);
            margin-bottom: 20px;
        }

        .error-message {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--text-dark);
        }

        .error-description {
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .btn {
            display: inline-block;
            background-color: var(--accent-blue);
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease;
            margin: 0 10px;
        }

        .btn:hover {
            background-color: #0056b3;
        }

        .language-section {
            margin-bottom: 30px;
            border-bottom: 1px solid #e0e0e0;
            padding-bottom: 20px;
        }

        @media (max-width: 600px) {
            .error-code {
                font-size: 80px;
            }
            .error-message {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="language-section">
            <div class="error-code">401</div>
            <h1 class="error-message"><%= language === 'ar' ? 'غير مصرح' : 'Unauthorized' %></h1>
            <p class="error-description"><%= language === 'ar' ? 'لا تملك صلاحيات الوصول لهذه الصفحة. يرجى تسجيل الدخول أو الاتصال بمسؤول.' : 'You do not have permission to access this page. Please log in or contact an administrator.' %></p>
            <a href="/" class="btn"><%= language === 'ar' ? 'العودة للصفحة الرئيسية' : 'Back to Home' %></a>
        </div>
    </div>
</body>
</html>