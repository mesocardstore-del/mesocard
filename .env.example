SERVER_PORT=5000
APP_NAME=Meso_Card
SESSION_SECRET=your_session_secret
BASE_URL=https://mesocard.com
BASE_URL_DEV=http://localhost:5000

MYSQL_HOST=127.0.0.1:3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=meso

SENDER_EMAIL=noreply@mesocard.com
EMAIL_HOST=email_host
EMAIL_PORT=port
EMAIL_USER=user
EMAIL_PASS=password


# Password Reset Token Expiration In Minutes
PASSWORD_RESET_TOKEN_EXPIRE=15

# JWT
JWT_SECRET=jwt_secret
JWT_LIFETIME=1h

# Cookie
COOKIE_SECRET=cookie_secret

# OAuth
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
FACEBOOK_APP_ID=facebook_app_id
FACEBOOK_APP_SECRET=facebook_app_secret

BCRYPT_SALT_ROUNDS=10

LOGIN_PROCESS_GAP_DELAY=100 # in millisecond